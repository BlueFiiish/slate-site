---
/*
  test-3d.astro — STANDALONE photoreal 3D laptop TEST page.

  Throwaway evaluation route: a genuinely 3D (Three.js / WebGL) MacBook that
  slowly auto-rotates (drag to orbit) with the REAL Ana rebuild screenshot
  mapped onto the screen, lit by an image-based environment (RoomEnvironment
  via PMREMGenerator — zero external download) with PBR aluminum, ACES tone
  mapping, a soft key light, and a contact-shadow catcher plane.

  Purpose: let Josia judge whether a real 3D device reads like an Apple
  product-page render (vs. the CSS LaptopShowcase) BEFORE committing to a 3D
  rebuild of the signature moment. NOT shipped on the homepage.

  This page deliberately does NOT touch index.astro, its components, or the
  sibling site/ / site-v2/ projects.
*/

// Resolve the real screenshot to a hashed, served URL Vite can fingerprint.
// (TextureLoader fetches this URL at runtime — it is NOT processed by
// astro:assets here, we just want the emitted file path.)
import anaScreenUrl from "../assets/captures/ana-desktop-top.png";

const screenSrc = typeof anaScreenUrl === "string" ? anaScreenUrl : anaScreenUrl.src;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>3D device test — Slate &amp; Co.</title>
    <style>
      :root {
        color-scheme: dark;
      }
      * {
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        height: 100%;
        background: #0b0e14; /* cyber theme page base (--bg) */
        overflow: hidden;
        font-family:
          ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
        color: #c9d3e0;
      }
      #stage {
        position: fixed;
        inset: 0;
        /* subtle cyber radial wash behind the device, matches the homepage mood */
        background:
          radial-gradient(
            70% 60% at 50% 38%,
            rgba(45, 212, 191, 0.07) 0%,
            transparent 60%
          ),
          radial-gradient(120% 120% at 50% 120%, #0d1119 0%, #0b0e14 55%);
      }
      #stage canvas {
        display: block;
        width: 100%;
        height: 100%;
        cursor: grab;
      }
      #stage canvas:active {
        cursor: grabbing;
      }
      .caption {
        position: fixed;
        left: 24px;
        bottom: 22px;
        z-index: 2;
        max-width: 30ch;
        pointer-events: none;
      }
      .caption__k {
        margin: 0;
        font-family: ui-monospace, "JetBrains Mono", "SF Mono", monospace;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #2dd4bf;
      }
      .caption__l {
        margin: 6px 0 0;
        font-size: 0.82rem;
        line-height: 1.4;
        color: #8a94a6;
      }
      .hint {
        position: fixed;
        right: 24px;
        bottom: 22px;
        z-index: 2;
        font-family: ui-monospace, "JetBrains Mono", monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #56616f;
        pointer-events: none;
      }
      /* prefers-reduced-motion: the script gates auto-rotate; this hint nudges */
      @media (prefers-reduced-motion: reduce) {
        .hint::after {
          content: " · motion reduced";
        }
      }
      .fallback {
        position: fixed;
        inset: 0;
        z-index: 1;
        display: grid;
        place-items: center;
        padding: 24px;
        text-align: center;
      }
      .fallback img {
        max-width: min(680px, 90vw);
        width: 100%;
        height: auto;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 30px 80px -30px rgba(0, 0, 0, 0.8);
      }
      .fallback p {
        margin-top: 16px;
        font-size: 0.8rem;
        color: #8a94a6;
      }
      /* Once WebGL takes over, hide the static fallback. */
      .is-live .fallback {
        display: none;
      }
    </style>
  </head>
  <body>
    <div id="stage" data-stage data-screen={screenSrc}>
      <!-- STATIC FALLBACK: complete with zero JS / no WebGL. Shows the real
           rebuilt screenshot so the page is never blank. -->
      <div class="fallback">
        <div>
          <img
            src={screenSrc}
            alt="The Ana's Confections homepage Slate rebuilt."
            width="2880"
            height="1800"
          />
          <p>3D device test — enable JavaScript / WebGL to orbit the model.</p>
        </div>
      </div>

      <p class="caption">
        <span class="caption__k">3D device test</span>
        <span class="caption__l">
          Real WebGL laptop · environment-lit PBR aluminum · live Ana rebuild on
          screen. Drag to rotate.
        </span>
      </p>
      <p class="hint">drag to orbit</p>
    </div>

    <script>
      import * as THREE from "three";
      import { OrbitControls } from "three/addons/controls/OrbitControls.js";
      import { RoomEnvironment } from "three/addons/environments/RoomEnvironment.js";

      const stage = document.querySelector<HTMLElement>("[data-stage]");
      const screenSrc = stage?.dataset.screen ?? "";

      // Bail cleanly if WebGL is unavailable — the static fallback stays.
      function hasWebGL(): boolean {
        try {
          const c = document.createElement("canvas");
          return !!(
            window.WebGLRenderingContext &&
            (c.getContext("webgl2") || c.getContext("webgl"))
          );
        } catch {
          return false;
        }
      }

      const reduce = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (stage && hasWebGL()) {
        boot(stage, screenSrc, reduce);
      }

      function boot(host: HTMLElement, src: string, reduceMotion: boolean) {
        // ---- Renderer: ACES + sRGB + soft shadows ----
        const renderer = new THREE.WebGLRenderer({
          antialias: true,
          alpha: true,
          powerPreference: "high-performance",
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(host.clientWidth, host.clientHeight);
        renderer.outputColorSpace = THREE.SRGBColorSpace;
        renderer.toneMapping = THREE.ACESFilmicToneMapping;
        renderer.toneMappingExposure = 1.05;
        renderer.shadowMap.enabled = true;
        renderer.shadowMap.type = THREE.PCFSoftShadowMap;
        host.appendChild(renderer.domElement);

        const scene = new THREE.Scene();

        // ---- Image-based lighting: RoomEnvironment -> PMREM (no download) ----
        const pmrem = new THREE.PMREMGenerator(renderer);
        const envTex = pmrem.fromScene(new RoomEnvironment(), 0.04).texture;
        scene.environment = envTex;

        // ---- Camera ----
        const camera = new THREE.PerspectiveCamera(
          32,
          host.clientWidth / host.clientHeight,
          0.1,
          100
        );
        camera.position.set(0, 1.6, 6.4);

        // ---- Soft key light (over the env fill) + a cool rim ----
        const key = new THREE.DirectionalLight(0xffffff, 2.2);
        key.position.set(-4, 6, 5);
        key.castShadow = true;
        key.shadow.mapSize.set(2048, 2048);
        key.shadow.camera.near = 1;
        key.shadow.camera.far = 20;
        key.shadow.camera.left = -6;
        key.shadow.camera.right = 6;
        key.shadow.camera.top = 6;
        key.shadow.camera.bottom = -6;
        key.shadow.bias = -0.0004;
        key.shadow.radius = 6;
        scene.add(key);

        const rim = new THREE.DirectionalLight(0x2dd4bf, 0.6); // cyber cyan rim
        rim.position.set(5, 2, -6);
        scene.add(rim);

        // Soft front fill so the aluminum faces aren't purely env-lit (keeps the
        // metal reading bright + even rather than crushing to black).
        const fill = new THREE.DirectionalLight(0xdfe7f0, 0.7);
        fill.position.set(2, 3, 8);
        scene.add(fill);

        // ---- Materials ----
        // Anodized silver-grey aluminum (PBR, env-reflective). Lighter base +
        // higher env intensity so the broad faces read as machined metal that
        // catches the studio reflections, not dark plastic.
        const aluminum = new THREE.MeshPhysicalMaterial({
          color: 0x9aa3ad,
          metalness: 0.95,
          roughness: 0.42,
          clearcoat: 0.2,
          clearcoatRoughness: 0.35,
          envMapIntensity: 2.0,
        });
        // Darker recessed deck / trackpad read.
        const aluminumDark = new THREE.MeshPhysicalMaterial({
          color: 0x4a525c,
          metalness: 0.92,
          roughness: 0.5,
          envMapIntensity: 1.4,
        });
        // Black glass-ish bezel surround.
        const bezelMat = new THREE.MeshPhysicalMaterial({
          color: 0x07090d,
          metalness: 0.2,
          roughness: 0.25,
          clearcoat: 1,
          clearcoatRoughness: 0.08,
          envMapIntensity: 1.4,
        });

        // ---- Build the laptop ----
        const laptop = new THREE.Group();
        scene.add(laptop);

        const W = 4.0; // body width
        const D = 2.7; // body depth
        const baseH = 0.12; // base thickness
        const r = 0.06; // edge round (via bevel-ish scaled boxes kept simple)

        // BASE / keyboard deck (a flat slab with a slight taper feel).
        const baseGeo = new THREE.BoxGeometry(W, baseH, D);
        const base = new THREE.Mesh(baseGeo, aluminum);
        base.position.set(0, baseH / 2, 0);
        base.castShadow = true;
        base.receiveShadow = true;
        laptop.add(base);

        // Keyboard deck inlay (recessed darker rectangle on top of the base).
        const deckGeo = new THREE.BoxGeometry(W * 0.86, 0.01, D * 0.62);
        const deck = new THREE.Mesh(deckGeo, aluminumDark);
        deck.position.set(0, baseH + 0.006, -D * 0.1);
        deck.receiveShadow = true;
        laptop.add(deck);

        // Trackpad hint.
        const padGeo = new THREE.BoxGeometry(W * 0.26, 0.012, D * 0.22);
        const pad = new THREE.Mesh(padGeo, aluminumDark);
        pad.position.set(0, baseH + 0.007, D * 0.24);
        laptop.add(pad);

        // ---- LID assembly (lid + screen), hinged at the back edge ----
        const lid = new THREE.Group();
        // hinge pivot at the back of the base
        lid.position.set(0, baseH, -D / 2);
        laptop.add(lid);

        const lidThick = 0.1;
        const lidH = 2.55; // lid height (screen panel size)
        // Outer aluminum lid shell.
        const lidGeo = new THREE.BoxGeometry(W, lidH, lidThick);
        const lidShell = new THREE.Mesh(lidGeo, aluminum);
        // place so its bottom edge sits at the hinge, extending upward
        lidShell.position.set(0, lidH / 2, -lidThick / 2);
        lidShell.castShadow = true;
        lidShell.receiveShadow = true;
        lid.add(lidShell);

        // Black bezel face on the front of the lid.
        const bezelGeo = new THREE.BoxGeometry(W * 0.97, lidH * 0.95, 0.02);
        const bezel = new THREE.Mesh(bezelGeo, bezelMat);
        bezel.position.set(0, lidH / 2, 0.001);
        lid.add(bezel);

        // ---- SCREEN: the real Ana rebuild, slightly emissive (glows) ----
        const screenW = W * 0.9;
        const screenH = screenW * (1800 / 2880); // keep 16:10 aspect
        const screenGeo = new THREE.PlaneGeometry(screenW, screenH);

        // Placeholder dark material until the texture loads.
        const screenMat = new THREE.MeshBasicMaterial({ color: 0x05080c });
        const screen = new THREE.Mesh(screenGeo, screenMat);
        // center the screen panel on the bezel
        screen.position.set(0, lidH / 2, 0.013);
        lid.add(screen);

        // Camera notch dot.
        const camDot = new THREE.Mesh(
          new THREE.CircleGeometry(0.02, 16),
          new THREE.MeshBasicMaterial({ color: 0x10151c })
        );
        camDot.position.set(0, lidH - 0.07, 0.014);
        lid.add(camDot);

        // tilt the lid open like a real laptop (~105 degrees from the deck)
        lid.rotation.x = THREE.MathUtils.degToRad(-15);

        // center the whole laptop vertically-ish in frame
        laptop.position.y = -0.6;
        laptop.rotation.x = THREE.MathUtils.degToRad(2);

        // ---- Load the screenshot texture ----
        new THREE.TextureLoader().load(
          src,
          (tex) => {
            tex.colorSpace = THREE.SRGBColorSpace;
            tex.anisotropy = renderer.capabilities.getMaxAnisotropy();
            const lit = new THREE.MeshStandardMaterial({
              map: tex,
              emissive: 0xffffff,
              emissiveMap: tex,
              emissiveIntensity: 0.42, // glows like a real display
              roughness: 0.5,
              metalness: 0,
              envMapIntensity: 0.4,
            });
            screen.material = lit;
            screenMat.dispose();
          },
          undefined,
          () => {
            // texture failed -> leave the dark placeholder, fallback img remains
            console.warn("[test-3d] screen texture failed to load");
          }
        );

        // ---- Contact-shadow catcher plane (shadow-only, transparent) ----
        const ground = new THREE.Mesh(
          new THREE.PlaneGeometry(40, 40),
          new THREE.ShadowMaterial({ opacity: 0.45 })
        );
        ground.rotation.x = -Math.PI / 2;
        ground.position.y = -0.62;
        ground.receiveShadow = true;
        scene.add(ground);

        // ---- OrbitControls: drag to rotate + gentle auto-rotate ----
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.08;
        controls.enablePan = false;
        controls.minDistance = 4.5;
        controls.maxDistance = 9;
        controls.minPolarAngle = THREE.MathUtils.degToRad(55);
        controls.maxPolarAngle = THREE.MathUtils.degToRad(92);
        controls.target.set(0, 0.2, 0);
        controls.autoRotate = !reduceMotion; // reduced-motion = settled, still
        controls.autoRotateSpeed = 0.9;
        controls.update();

        // ---- Resize ----
        function onResize() {
          const w = host.clientWidth;
          const h = host.clientHeight;
          camera.aspect = w / h;
          camera.updateProjectionMatrix();
          renderer.setSize(w, h);
        }
        window.addEventListener("resize", onResize);

        host.classList.add("is-live");

        // ---- Render loop ----
        let raf = 0;
        let running = true;
        function tick() {
          if (!running) return;
          controls.update();
          renderer.render(scene, camera);
          raf = requestAnimationFrame(tick);
        }
        tick();

        // ---- Route-leave / pagehide cleanup: dispose the WebGL context ----
        function dispose() {
          running = false;
          cancelAnimationFrame(raf);
          window.removeEventListener("resize", onResize);
          controls.dispose();
          scene.traverse((obj) => {
            const m = obj as THREE.Mesh;
            if (m.geometry) m.geometry.dispose();
            const mat = m.material as
              | THREE.Material
              | THREE.Material[]
              | undefined;
            if (Array.isArray(mat)) mat.forEach((x) => x.dispose());
            else if (mat) mat.dispose();
          });
          envTex.dispose();
          pmrem.dispose();
          renderer.dispose();
          renderer.forceContextLoss();
          if (renderer.domElement.parentNode) {
            renderer.domElement.parentNode.removeChild(renderer.domElement);
          }
        }
        document.addEventListener("astro:before-swap", dispose, { once: true });
        window.addEventListener("pagehide", dispose, { once: true });
      }
    </script>
  </body>
</html>
