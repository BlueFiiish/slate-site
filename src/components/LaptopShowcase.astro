---
/*
  LaptopShowcase — a scroll-scrubbed CINEMATIC DEMO in the professional-cyber
  theme. The laptop is the HERO: it sits CENTERED in the pinned viewport with
  generous room below for a caption that is ALWAYS fully visible. For each of
  six features the DEVICE itself demonstrates the feature on the real rebuilt
  site. SHOW, DON'T TELL.

  NEW in this overhaul:
  - Laptop is vertically centered in the pin with reserved caption space below;
    captions never clip.
  - TRUE LAPTOP -> PHONE MORPH: the same device frame physically transforms —
    its width narrows, the screen's clip-path squeezes from 16:10 to a 9:19.5
    phone column, corner radius grows, base folds away, a notch fades in. One
    object morphing, not a crossfade to a separate phone.
  - DRAMATIC MOVEMENT: each beat transition adds a kinetic device motion — a
    Y-axis flip / barrel rotate — on top of the zoom + pronounced tilt.
  - CYBER HUD: a faint grid, corner brackets/reticle, scan glow, a live HUD
    metric label, and connector lines frame the device during the sequence.

  HOW IT SHIPS (per the studio's elite-toolchain + motion rules):
  - Performance-budgeted island. GSAP + ScrollTrigger loaded LAZILY via a
    dynamic import gated behind an IntersectionObserver, so the GSAP bundle is
    fetched only when the section nears the viewport and NEVER blocks LCP.
  - DOM + CSS + GSAP — NO mp4/webm. Real screenshots (astro:assets, AVIF,
    dimension-locked) + real text; every transition is transform / opacity /
    clip-path only (compositor-friendly).
  - Static fallback: with JS off (or before hydration) the section renders
    complete and legible — the laptop shows the closing wordmark and ALL SIX
    features render as a readable list below. Nothing is hidden.
  - prefers-reduced-motion: the script bails before building; CSS shows the
    settled end-state, no scrub.
  - Route-leave cleanup: the gsap.context is reverted on astro:before-swap AND
    pagehide so View-Transition navigation can't leak instances/memory.
  - Budget: section height is reserved (pin host) so pinning adds zero CLS.
*/
import { Image } from "astro:assets";
import anaHero from "../assets/captures/ana-desktop-top.png";
import anaGallery from "../assets/captures/ana-desktop-gallery.png";
import anaMobile from "../assets/captures/ana-mobile-top.png";
import anaBefore from "../assets/captures/ana-before-desktop.png";

// The six features, in demo order. Each one is DEMONSTRATED on the device;
// the caption is a tiny mono kicker + one short line that labels what's shown.
const features = [
  {
    n: "01",
    kicker: "Custom-designed",
    line: "Drawn from scratch for your business — never a template.",
  },
  {
    n: "02",
    kicker: "Loads in about a second",
    line: "Clean Astro code that paints fast, even on a phone.",
  },
  {
    n: "03",
    kicker: "Right on every phone",
    line: "The same site, designed to fit any screen.",
  },
  {
    n: "04",
    kicker: "Your Google listing, handled",
    line: "Your map and search presence set up and looked after.",
  },
  {
    n: "05",
    kicker: "Real before & afters",
    line: "An honest rebuild of a live site — see the difference.",
  },
  {
    n: "06",
    kicker: "One person, start to finish",
    line: "You reach the maker — no hand-offs, no call centre.",
  },
];
---

<section class="showcase" id="showcase" aria-labelledby="showcase-heading">
  <!-- TRACK: its height is reserved statically in CSS (var via .js-motion) so
       the sticky pin is HEIGHT-NEUTRAL — no ScrollTrigger pin, no spacer, so
       nothing below ever shifts. CLS = 0. With JS off the track collapses. -->
  <div class="showcase__track" data-showcase-track>
    <div class="showcase__pin" data-showcase-pin>
      <!-- Cyber HUD backdrop: faint grid + scan glow, behind the device.
           Decorative, aria-hidden, painted only once live (no static cost). -->
      <div class="hud" data-hud aria-hidden="true">
        <div class="hud__grid"></div>
        <div class="hud__scan" data-hud-scan></div>
      </div>

      <div class="showcase__inner container container--feature">
        <header class="showcase__head" data-showcase-head>
          <p class="eyebrow">A closer look</p>
          <h2 id="showcase-heading" class="showcase__headline">
            Watch what you actually get.
          </h2>
          <p class="showcase__scrollhint" data-showcase-hint aria-hidden="true">
            Scroll to play
          </p>
        </header>

        <!-- STAGE: the device is centered; the caption sits in reserved room
             BELOW it and is always fully visible. -->
        <div class="showcase__stage">
          <!-- THE DEVICE: pinned, zooming, tilting, flipping (pronounced 3D). -->
          <div class="showcase__device" data-showcase-device>
            <div class="showcase__glow" aria-hidden="true"></div>

            <!-- Corner reticle brackets + connector HUD label, around device. -->
            <div class="reticle" data-reticle aria-hidden="true">
              <span class="reticle__c reticle__c--tl"></span>
              <span class="reticle__c reticle__c--tr"></span>
              <span class="reticle__c reticle__c--bl"></span>
              <span class="reticle__c reticle__c--br"></span>
              <span class="reticle__line" data-reticle-line></span>
              <span class="hudlabel" data-hudlabel>
                <span class="hudlabel__dot"></span>
                <span class="hudlabel__k" data-hudlabel-k>RENDER</span>
                <span class="hudlabel__v" data-hudlabel-v>READY</span>
              </span>
            </div>

            <!-- LAPTOP — the hero. The SAME frame morphs into a phone (beat 3)
                 by narrowing + clipping + rounding; base folds away. -->
            <figure class="laptop" data-laptop>
              <div class="laptop__bezel" data-bezel>
                <span class="laptop__cam" aria-hidden="true"></span>
                <span class="laptop__notch" data-notch aria-hidden="true"></span>
                <div class="laptop__screen" data-screen>
                  <!-- == FRAME: hero (pan/zoom across the bespoke design) == -->
                  <div class="frame" data-frame="hero" data-active>
                    <Image
                      class="frame__img frame__img--pan"
                      data-pan
                      src={anaHero}
                      alt="The Ana's Confections homepage Slate rebuilt, shown full-screen."
                      width={1280}
                      sizes="(min-width: 1024px) 780px, 92vw"
                      format="avif"
                      loading="lazy"
                    />
                  </div>

                  <!-- == FRAME: gallery (the fast-paint cascade demo) == -->
                  <div class="frame frame--cascade" data-frame="gallery" aria-hidden="true">
                    <Image
                      class="frame__img"
                      src={anaGallery}
                      alt="A section of Ana's rebuilt site showing the cake gallery grid."
                      width={1280}
                      sizes="(min-width: 1024px) 780px, 92vw"
                      format="avif"
                      loading="lazy"
                    />
                    <span class="cascade__row" data-cascade aria-hidden="true"></span>
                    <span class="cascade__row" data-cascade aria-hidden="true"></span>
                    <span class="cascade__row" data-cascade aria-hidden="true"></span>
                    <span class="speedcue" data-speedcue aria-hidden="true">
                      <span class="speedcue__dot"></span>0.8s
                    </span>
                  </div>

                  <!-- == FRAME: mobile screenshot (revealed under the morph) == -->
                  <div class="frame frame--mobile" data-frame="mobile" aria-hidden="true">
                    <Image
                      class="frame__img frame__img--mobile"
                      src={anaMobile}
                      alt="The same Ana's Confections site shown on a phone."
                      width={760}
                      sizes="(min-width: 1024px) 300px, 60vw"
                      format="avif"
                      loading="lazy"
                    />
                  </div>

                  <!-- == FRAME: Google Business listing (designed mock) == -->
                  <div class="frame frame--google" data-frame="google" aria-hidden="true">
                    <div class="gbiz" aria-hidden="true">
                      <div class="gbiz__main">
                        <p class="gbiz__kicker">Bakery &middot; Rosenberg, TX</p>
                        <h3 class="gbiz__name">Ana&rsquo;s Confections</h3>
                        <p class="gbiz__rating">
                          <strong>4.8</strong>
                          <span class="gbiz__stars" aria-hidden="true">
                            <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span class="is-half">&#9733;</span>
                          </span>
                          <span class="gbiz__count">Google reviews</span>
                        </p>
                        <ul class="gbiz__rows">
                          <li><span class="gbiz__ico" data-ico="open"></span><span><strong>Open</strong> &middot; Closes 6 PM</span></li>
                          <li><span class="gbiz__ico" data-ico="pin"></span>808 Third St, Rosenberg, TX</li>
                          <li><span class="gbiz__ico" data-ico="phone"></span>(979) 533-0651</li>
                        </ul>
                        <div class="gbiz__chips">
                          <span class="gbiz__chip gbiz__chip--accent">Directions</span>
                          <span class="gbiz__chip">Website</span>
                          <span class="gbiz__chip">Call</span>
                        </div>
                      </div>
                      <div class="gbiz__map" aria-hidden="true">
                        <span class="gbiz__road gbiz__road--a"></span>
                        <span class="gbiz__road gbiz__road--b"></span>
                        <span class="gbiz__road gbiz__road--c"></span>
                        <span class="gbiz__marker"></span>
                      </div>
                    </div>
                  </div>

                  <!-- == FRAME: before/after wipe (old template -> rebuild) == -->
                  <div class="frame frame--wipe" data-frame="wipe" aria-hidden="true">
                    <Image
                      class="frame__img"
                      src={anaHero}
                      alt="The rebuilt Ana's Confections homepage."
                      width={1280}
                      sizes="(min-width: 1024px) 780px, 92vw"
                      format="avif"
                      loading="lazy"
                    />
                    <div class="wipe__before" data-wipe>
                      <Image
                        class="frame__img"
                        src={anaBefore}
                        alt="The original Ana's Confections template site, before the rebuild."
                        width={1280}
                        sizes="(min-width: 1024px) 780px, 92vw"
                        format="avif"
                        loading="lazy"
                      />
                      <span class="wipe__tag">Before</span>
                    </div>
                    <span class="wipe__handle" data-wipe-handle aria-hidden="true"></span>
                    <span class="wipe__tag wipe__tag--after">After</span>
                  </div>

                  <!-- == CLOSING wordmark (also the no-JS settled end-state) == -->
                  <div class="closing" data-closing>
                    <span class="closing__mark">Slate &amp; Co.</span>
                    <p class="closing__line">One maker. Real rebuilds.</p>
                  </div>

                  <span class="screen__vignette" aria-hidden="true"></span>
                  <span class="screen__scanline" data-screenscan aria-hidden="true"></span>
                </div>
              </div>
              <div class="laptop__base" data-base aria-hidden="true">
                <span class="laptop__hinge"></span>
              </div>
            </figure>
          </div>

          <!-- Caption room is RESERVED below the device (in flow, zero CLS) and
               the caption itself sits inside it — always fully visible. -->
          <div class="showcase__capwrap">
            <div class="showcase__caption" data-caption aria-hidden="true">
              {
                features.map((feat) => (
                  <p class="cap" data-cap={feat.n}>
                    <span class="cap__kicker">
                      <span class="cap__n">{feat.n}</span>
                      {feat.kicker}
                    </span>
                    <span class="cap__line">{feat.line}</span>
                  </p>
                ))
              }
            </div>
          </div>
        </div>

        <p class="showcase__credit">
          A real rebuild: <strong>Ana&rsquo;s Confections</strong>, Rosenberg TX.
        </p>
      </div>
    </div>
  </div>

  <!-- == STATIC / NO-JS / a11y list. OUTSIDE the sticky track so it never pins
       and never shifts. Always in the DOM so all six features are legible
       without the demo; the live island hides it. == -->
  <ul class="showcase__list container container--feature" data-showcase-list>
    {
      features.map((feat) => (
        <li class="svc">
          <span class="svc__num">{feat.n}</span>
          <div>
            <p class="svc__title">{feat.kicker}</p>
            <p class="svc__body">{feat.line}</p>
          </div>
        </li>
      ))
    }
  </ul>
</section>

<script>
  // ----------------------------------------------------------------------
  // Island-on-visible: load GSAP + wire the scrubbed demo only when the
  // section nears the viewport, and only when motion is allowed. Everything
  // is progressive enhancement over the complete static markup above.
  // ----------------------------------------------------------------------
  type STModule = typeof import("gsap/ScrollTrigger");

  const section = document.querySelector<HTMLElement>("#showcase");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");

    let built = false;
    let teardown: (() => void) | null = null;

    function settled(): Promise<void> {
      return new Promise((resolve) => {
        const ready = (document as any).fonts?.ready ?? Promise.resolve();
        ready.then(() => {
          requestAnimationFrame(() =>
            requestAnimationFrame(() => resolve())
          );
        });
      });
    }

    async function build() {
      if (built) return;
      built = true;

      const [{ gsap }, mod] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger") as Promise<STModule>,
        settled(),
      ]);
      const ScrollTrigger = mod.ScrollTrigger;
      gsap.registerPlugin(ScrollTrigger);

      const q = <T extends HTMLElement = HTMLElement>(sel: string) =>
        section!.querySelector<T>(sel);
      const qa = (sel: string) =>
        Array.from(section!.querySelectorAll<HTMLElement>(sel));

      const track = q("[data-showcase-track]");
      const device = q("[data-showcase-device]");
      const laptop = q("[data-laptop]");
      const bezel = q("[data-bezel]");
      const screen = q("[data-screen]");
      const base = q("[data-base]");
      const notch = q("[data-notch]");
      const hint = q("[data-showcase-hint]");
      const closing = q("[data-closing]");
      if (!track || !device || !laptop || !bezel || !screen) return;

      const frame = (name: string) => q(`[data-frame="${name}"]`);
      const f = {
        hero: frame("hero"),
        gallery: frame("gallery"),
        mobile: frame("mobile"),
        google: frame("google"),
        wipe: frame("wipe"),
      };
      const pan = q("[data-pan]");
      const cascade = qa("[data-cascade]");
      const speedcue = q("[data-speedcue]");
      const wipeBefore = q("[data-wipe]");
      const wipeHandle = q("[data-wipe-handle]");
      const caps = qa("[data-cap]");
      const cap = (n: string) => caps.find((c) => c.dataset.cap === n) || null;

      // HUD bits
      const hud = q("[data-hud]");
      const hudScan = q("[data-hud-scan]");
      const reticle = q("[data-reticle]");
      const reticleLine = q("[data-reticle-line]");
      const hudK = q("[data-hudlabel-k]");
      const hudV = q("[data-hudlabel-v]");
      const screenScan = q("[data-screenscan]");

      // Set the rolling HUD label to a beat's spec text.
      const setHud = (k: string, v: string) => {
        if (hudK) hudK.textContent = k;
        if (hudV) hudV.textContent = v;
      };

      // Hand control to GSAP: CSS static end-state styles step aside.
      section!.classList.add("is-live");

      const ctx = gsap.context(() => {
        // ----- explicit start-state (transform / opacity / clip only) -----
        gsap.set(device, { scale: 0.84, rotateX: 13, rotateY: -17, y: 6, transformOrigin: "50% 55%" });
        gsap.set(laptop, { autoAlpha: 1, transformOrigin: "50% 56%" });

        const allFrames = [f.hero, f.gallery, f.mobile, f.google, f.wipe].filter(
          Boolean
        ) as HTMLElement[];
        gsap.set(allFrames, { autoAlpha: 0 });
        gsap.set(f.hero!, { autoAlpha: 1 });
        if (pan) gsap.set(pan, { scale: 1.18, yPercent: 0, xPercent: 0 });

        gsap.set(cascade, { yPercent: 16, autoAlpha: 0 });
        if (speedcue) gsap.set(speedcue, { autoAlpha: 0, scale: 0.9 });
        if (wipeBefore) gsap.set(wipeBefore, { clipPath: "inset(0 0% 0 0)" });
        // handle travels via transform (x) only -> no layout shift. Its full
        // travel = the screen's pixel width (recomputed on refresh).
        const seamW = () => (screen ? screen.getBoundingClientRect().width : 600);
        if (wipeHandle) gsap.set(wipeHandle, { x: seamW(), autoAlpha: 0 });

        // Morph state vars: --morph 0 = laptop, 1 = phone. CSS reads it to
        // narrow the bezel, clip the screen to a phone column, round corners,
        // fold the base and reveal the notch — all from ONE driven value.
        if (bezel) gsap.set(bezel, { "--morph": 0 } as any);
        if (notch) gsap.set(notch, { autoAlpha: 0 });

        gsap.set(caps, { autoAlpha: 0, y: 14 });
        if (closing) gsap.set(closing, { autoAlpha: 0, scale: 1.06 });

        // HUD start state
        if (hud) gsap.set(hud, { autoAlpha: 0 });
        if (reticle) gsap.set(reticle, { autoAlpha: 0, scale: 1.04 });
        if (hudScan) gsap.set(hudScan, { yPercent: -120, autoAlpha: 0 });
        if (screenScan) gsap.set(screenScan, { yPercent: -120, autoAlpha: 0 });
        setHud("RENDER", "READY");

        const tl = gsap.timeline({
          defaults: { ease: "none" },
          scrollTrigger: {
            trigger: track,
            start: "top top",
            end: "bottom bottom",
            scrub: 0.7,
            invalidateOnRefresh: true,
          },
        });

        const E = "power2.inOut";

        const capIn = (n: string, at: number) => {
          const c = cap(n);
          if (c) tl.to(c, { autoAlpha: 1, y: 0, ease: "power2.out", duration: 0.04 }, at);
        };
        const capOut = (n: string, at: number) => {
          const c = cap(n);
          if (c) tl.to(c, { autoAlpha: 0, y: -12, ease: "power2.in", duration: 0.03 }, at);
        };

        // A reusable "scan sweep" inside the screen on a beat change.
        const scanSweep = (at: number) => {
          if (!screenScan) return;
          tl.fromTo(
            screenScan,
            { yPercent: -120, autoAlpha: 0.9 },
            { yPercent: 120, autoAlpha: 0, ease: "power1.in", duration: 0.06 },
            at
          );
        };

        // ============================================================
        // BEAT 0 (0.00 -> 0.08): OPEN. Device zooms in, tilt settles, the
        // HUD frame powers on (grid + reticle fade in, scan sweeps).
        // ============================================================
        tl.to(device, { scale: 1, rotateX: 6, rotateY: -8, y: 0, ease: E, duration: 0.08 }, 0);
        if (hint) tl.to(hint, { autoAlpha: 0, duration: 0.03 }, 0.02);
        if (hud) tl.to(hud, { autoAlpha: 1, ease: "power2.out", duration: 0.05 }, 0.01);
        if (reticle) tl.to(reticle, { autoAlpha: 1, scale: 1, ease: "power2.out", duration: 0.06 }, 0.02);
        if (hudScan)
          tl.fromTo(hudScan, { yPercent: -120, autoAlpha: 0.5 }, { yPercent: 120, autoAlpha: 0, ease: "power1.in", duration: 0.07 }, 0.02);

        // ============================================================
        // BEAT 1 (0.08 -> 0.18): CUSTOM-DESIGNED. Tilt flattens, a barrel
        // rotate settles, the screen does a slow premium pan/zoom. Caption 01.
        // ============================================================
        tl.to(device, { rotateX: 0, rotateY: 0, rotateZ: 0, ease: E, duration: 0.06 }, 0.08);
        capIn("01", 0.1);
        tl.call(() => setHud("DESIGN", "BESPOKE"), [], 0.09);
        if (pan)
          tl.to(pan, { scale: 1.04, yPercent: -10, xPercent: 4, ease: E, duration: 0.14 }, 0.06);

        // ============================================================
        // BEAT 2 (0.20 -> 0.32): LOADS IN ~1s. A quick Y-flip spins to the
        // gallery; rows SNAP up + a "0.8s" cue pops. Caption 02.
        // ============================================================
        capOut("01", 0.2);
        // dramatic Y-axis flip transition between frames
        tl.to(device, { rotateY: -90, ease: "power2.in", duration: 0.04 }, 0.2);
        tl.set(f.hero!, { autoAlpha: 0 }, 0.24);
        tl.set(f.gallery!, { autoAlpha: 1 }, 0.24);
        scanSweep(0.24);
        tl.to(device, { rotateY: 0, ease: "power2.out", duration: 0.05 }, 0.24);
        capIn("02", 0.25);
        tl.call(() => setHud("PAINT", "0.8s"), [], 0.23);
        tl.to(
          cascade,
          { yPercent: 0, autoAlpha: 1, ease: "power3.out", duration: 0.05, stagger: 0.018 },
          0.25
        );
        if (speedcue)
          tl.to(speedcue, { autoAlpha: 1, scale: 1, ease: "back.out(2)", duration: 0.05 }, 0.28);
        tl.to(cascade, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.31);

        // ============================================================
        // BEAT 3 (0.34 -> 0.50): RIGHT ON EVERY PHONE — the TRUE MORPH.
        // The SAME frame physically transforms laptop -> phone: bezel narrows,
        // the screen clips to a 9:19.5 column, corners round, base folds away,
        // notch fades in. Screen content crossfades to the mobile shot. The
        // money beat. Caption 03.
        // ============================================================
        capOut("02", 0.33);
        if (speedcue) tl.to(speedcue, { autoAlpha: 0, duration: 0.03 }, 0.33);
        tl.call(() => setHud("VIEWPORT", "390px"), [], 0.34);
        // crossfade screen content gallery -> mobile under the clip
        tl.to(f.gallery!, { autoAlpha: 0, ease: E, duration: 0.05 }, 0.35);
        tl.to(f.mobile!, { autoAlpha: 1, ease: E, duration: 0.05 }, 0.36);
        // a subtle barrel rotate as it squeezes — feels physical
        tl.to(device, { rotateY: 7, ease: "power2.inOut", duration: 0.07 }, 0.35);
        tl.to(device, { rotateY: 0, ease: "power2.inOut", duration: 0.07 }, 0.42);
        // THE morph: drive --morph 0 -> 1 (CSS does the geometry). Slower +
        // wider window so the mid-transition is clearly visible while scrolling.
        if (bezel)
          tl.to(bezel, { "--morph": 1, ease: "power2.inOut", duration: 0.13 } as any, 0.36);
        if (base)
          tl.to(base, { autoAlpha: 0, scaleX: 0.2, ease: "power2.in", duration: 0.09 }, 0.36);
        if (notch)
          tl.to(notch, { autoAlpha: 1, ease: "power2.out", duration: 0.05 }, 0.47);
        capIn("03", 0.49);

        // hold the phone a beat, then morph BACK to laptop for the next beat
        tl.to(f.mobile!, { autoAlpha: 0, ease: E, duration: 0.05 }, 0.55);
        if (notch) tl.to(notch, { autoAlpha: 0, duration: 0.03 }, 0.55);
        if (bezel)
          tl.to(bezel, { "--morph": 0, ease: "power2.inOut", duration: 0.1 } as any, 0.56);
        if (base)
          tl.to(base, { autoAlpha: 1, scaleX: 1, ease: "power2.out", duration: 0.07 }, 0.58);
        capOut("03", 0.58);

        // ============================================================
        // BEAT 4 (0.64 -> 0.72): GOOGLE LISTING, HANDLED. A Y-flip reveals
        // the designed Google-Business mock. Caption 04.
        // ============================================================
        tl.set(f.gallery!, { autoAlpha: 1 }, 0.6); // restore desktop bg under flip
        tl.to(device, { rotateY: 90, ease: "power2.in", duration: 0.04 }, 0.64);
        tl.set(f.gallery!, { autoAlpha: 0 }, 0.68);
        tl.set(f.google!, { autoAlpha: 1 }, 0.68);
        scanSweep(0.68);
        tl.to(device, { rotateY: 0, ease: "power2.out", duration: 0.05 }, 0.68);
        tl.call(() => setHud("LOCAL SEO", "INDEXED"), [], 0.67);
        capIn("04", 0.7);

        // ============================================================
        // BEAT 5 (0.72 -> 0.86): REAL BEFORE & AFTERS. The old template wipes
        // left-to-right to reveal the rebuild (handle tracks seam). Caption 05.
        // ============================================================
        capOut("04", 0.76);
        tl.to(f.google!, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.76);
        tl.to(f.wipe!, { autoAlpha: 1, ease: E, duration: 0.04 }, 0.77);
        tl.call(() => setHud("REBUILD", "LIVE"), [], 0.76);
        capIn("05", 0.8);
        if (wipeHandle) tl.set(wipeHandle, { autoAlpha: 1 }, 0.78);
        if (wipeBefore)
          tl.fromTo(
            wipeBefore,
            { clipPath: "inset(0 0% 0 0)" },
            { clipPath: "inset(0 100% 0 0)", ease: E, duration: 0.1 },
            0.8
          );
        if (wipeHandle)
          tl.fromTo(wipeHandle, { x: seamW() }, { x: 0, ease: E, duration: 0.1 }, 0.8);
        if (wipeHandle) tl.to(wipeHandle, { autoAlpha: 0, duration: 0.03 }, 0.9);

        // ============================================================
        // BEAT 6 (0.88 -> 1.00): ONE PERSON. Quiet close — the screen settles
        // to the Slate & Co. wordmark with a confident push-in; HUD dims out.
        // Caption 06.
        // ============================================================
        capOut("05", 0.9);
        tl.to(f.wipe!, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.9);
        if (closing)
          tl.to(closing, { autoAlpha: 1, scale: 1, ease: "power2.out", duration: 0.06 }, 0.91);
        tl.call(() => setHud("STUDIO", "SLATE"), [], 0.9);
        capIn("06", 0.93);
        tl.to(device, { scale: 1.02, ease: "power1.out", duration: 0.06 }, 0.93);
        if (reticle) tl.to(reticle, { autoAlpha: 0.55, ease: "power1.out", duration: 0.05 }, 0.95);
        if (hud) tl.to(hud, { autoAlpha: 0.5, ease: "power1.out", duration: 0.05 }, 0.95);
      }, section!);

      teardown = () => {
        ctx.revert();
        section!.classList.remove("is-live");
        built = false;
        teardown = null;
      };
    }

    function maybeBuild() {
      if (reduce.matches) return;
      build();
    }

    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              io.disconnect();
              maybeBuild();
            }
          }
        },
        // load a little before the section enters view, but not so early that
        // it competes with the hero/LCP on first paint.
        { rootMargin: "300px 0px 300px 0px" }
      );
      io.observe(section);
    } else {
      maybeBuild();
    }

    reduce.addEventListener("change", () => {
      if (reduce.matches && teardown) teardown();
    });

    // ---- Route-leave cleanup (View Transitions + bfcache) ----
    const cleanup = () => {
      if (teardown) teardown();
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
    window.addEventListener("pagehide", cleanup, { once: true });
  }
</script>

