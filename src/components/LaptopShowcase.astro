---
/*
  LaptopShowcase — a scroll-scrubbed CINEMATIC DEMO where the laptop is the
  HERO and, for each of six features, the DEVICE ITSELF demonstrates the
  feature on the real rebuilt site. SHOW, DON'T TELL: the screen pans, the page
  snaps in fast, the laptop MORPHS into a phone, a designed Google listing
  slides up, an old template wipes into the rebuild, then it settles on the
  studio wordmark. A small, subtle caption labels each beat beside the device —
  it never covers the laptop, never competes with it. No colored panel.

  HOW IT SHIPS (per the studio's elite-toolchain + motion rules):
  - Performance-budgeted island. GSAP + ScrollTrigger is loaded LAZILY via a
    dynamic import gated behind an IntersectionObserver (island-on-visible), so
    the GSAP bundle is fetched only when the section nears the viewport and
    NEVER blocks the hero/LCP. Upfront JS is tiny (the observer shim only).
  - The whole demo is DOM + CSS + GSAP — NO mp4/webm. Real screenshots
    (astro:assets, AVIF, dimension-locked) plus real text; every transition is
    transform / opacity / clip-path only (compositor-friendly).
  - Static fallback: with JS off (or before hydration) the section renders
    complete and legible — the laptop shows the hero rebuild and ALL SIX
    features render as a readable list below it. Nothing is hidden.
  - prefers-reduced-motion: the script bails before building; CSS shows the
    settled end-state (closing frame + the six features listed), no scrub.
  - Route-leave cleanup: the gsap.context is reverted on astro:before-swap AND
    pagehide so View-Transition navigation can't leak instances/memory.
  - Budget: section height is reserved (pin host) so pinning adds zero CLS.
*/
import { Image } from "astro:assets";
import anaHero from "../assets/captures/ana-desktop-top.png";
import anaGallery from "../assets/captures/ana-desktop-gallery.png";
import anaLower from "../assets/captures/ana-desktop-lower.png";
import anaMobile from "../assets/captures/ana-mobile-top.png";
import anaBefore from "../assets/captures/ana-before-desktop.png";

// The six features, in demo order. Each one is DEMONSTRATED on the device;
// the caption is a tiny kicker + one short line that labels what's shown.
const features = [
  {
    n: "01",
    kicker: "Custom-designed",
    line: "Drawn from scratch for your business — never a template.",
  },
  {
    n: "02",
    kicker: "Loads in about a second",
    line: "Clean Astro code that paints fast, even on a phone.",
  },
  {
    n: "03",
    kicker: "Right on every phone",
    line: "The same site, designed to fit any screen.",
  },
  {
    n: "04",
    kicker: "Your Google listing, handled",
    line: "Your map and search presence set up and looked after.",
  },
  {
    n: "05",
    kicker: "Real before & afters",
    line: "An honest rebuild of a live site — see the difference.",
  },
  {
    n: "06",
    kicker: "One person, start to finish",
    line: "You reach the maker — no hand-offs, no call centre.",
  },
];
---

<section class="showcase" id="showcase" aria-labelledby="showcase-heading">
  <!-- TRACK: its height is reserved statically in CSS (var(--track-h)) so the
       scrubbed pin is HEIGHT-NEUTRAL — ScrollTrigger pins the inner viewport
       with pinSpacing:false and never inserts a spacer, so nothing below ever
       shifts. CLS = 0. With JS off, the track collapses to content height. -->
  <div class="showcase__track" data-showcase-track>
    <div class="showcase__pin" data-showcase-pin>
    <div class="showcase__inner container container--feature">
      <header class="showcase__head" data-showcase-head>
        <p class="eyebrow">A closer look</p>
        <h2 id="showcase-heading" class="showcase__headline">
          Watch what you actually get.
        </h2>
        <p class="showcase__scrollhint" data-showcase-hint aria-hidden="true">
          Scroll to play
        </p>
      </header>

      <!-- The stage holds the device (centered) and the small caption that
           sits beside it. On the demo, the caption swaps per beat; statically
           it's empty (the full list below carries the no-JS content). -->
      <div class="showcase__stage">
        <!-- THE DEVICE: pinned, zooming, tilting (pronounced 3D). -->
        <div class="showcase__device" data-showcase-device>
          <div class="showcase__glow" aria-hidden="true"></div>

          <!-- LAPTOP — the hero. Recedes/folds for the phone morph. -->
          <figure class="laptop" data-laptop>
            <div class="laptop__bezel">
              <span class="laptop__cam" aria-hidden="true"></span>
              <div class="laptop__screen" data-screen>
                <!-- == FRAME: hero (pan/zoom across the bespoke design) == -->
                <div class="frame" data-frame="hero" data-active>
                  <Image
                    class="frame__img frame__img--pan"
                    data-pan
                    src={anaHero}
                    alt="The Ana's Confections homepage Slate rebuilt, shown full-screen."
                    width={1280}
                    sizes="(min-width: 1024px) 780px, 92vw"
                    format="avif"
                    loading="lazy"
                  />
                </div>

                <!-- == FRAME: gallery (the fast-paint cascade demo) == -->
                <div class="frame frame--cascade" data-frame="gallery" aria-hidden="true">
                  <Image
                    class="frame__img"
                    src={anaGallery}
                    alt="A section of Ana's rebuilt site showing the cake gallery grid."
                    width={1280}
                    sizes="(min-width: 1024px) 780px, 92vw"
                    format="avif"
                    loading="lazy"
                  />
                  <!-- light "snap-in" sheen rows to convey instant paint -->
                  <span class="cascade__row" data-cascade aria-hidden="true"></span>
                  <span class="cascade__row" data-cascade aria-hidden="true"></span>
                  <span class="cascade__row" data-cascade aria-hidden="true"></span>
                  <span class="speedcue" data-speedcue aria-hidden="true">
                    <span class="speedcue__dot"></span>0.8s
                  </span>
                </div>

                <!-- == FRAME: Google Business listing (designed mock) == -->
                <div class="frame frame--google" data-frame="google" aria-hidden="true">
                  <div class="gbiz" aria-hidden="true">
                    <div class="gbiz__main">
                      <p class="gbiz__kicker">Bakery &middot; Rosenberg, TX</p>
                      <h3 class="gbiz__name">Ana&rsquo;s Confections</h3>
                      <p class="gbiz__rating">
                        <strong>4.8</strong>
                        <span class="gbiz__stars" aria-hidden="true">
                          <span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span>&#9733;</span><span class="is-half">&#9733;</span>
                        </span>
                        <span class="gbiz__count">Google reviews</span>
                      </p>
                      <ul class="gbiz__rows">
                        <li><span class="gbiz__ico" data-ico="open"></span><span><strong>Open</strong> &middot; Closes 6 PM</span></li>
                        <li><span class="gbiz__ico" data-ico="pin"></span>808 Third St, Rosenberg, TX</li>
                        <li><span class="gbiz__ico" data-ico="phone"></span>(979) 533-0651</li>
                      </ul>
                      <div class="gbiz__chips">
                        <span class="gbiz__chip gbiz__chip--accent">Directions</span>
                        <span class="gbiz__chip">Website</span>
                        <span class="gbiz__chip">Call</span>
                      </div>
                    </div>
                    <div class="gbiz__map" aria-hidden="true">
                      <span class="gbiz__road gbiz__road--a"></span>
                      <span class="gbiz__road gbiz__road--b"></span>
                      <span class="gbiz__road gbiz__road--c"></span>
                      <span class="gbiz__marker"></span>
                    </div>
                  </div>
                </div>

                <!-- == FRAME: before/after wipe (old template -> rebuild) == -->
                <div class="frame frame--wipe" data-frame="wipe" aria-hidden="true">
                  <!-- AFTER (rebuild) sits underneath, full -->
                  <Image
                    class="frame__img"
                    src={anaHero}
                    alt="The rebuilt Ana's Confections homepage."
                    width={1280}
                    sizes="(min-width: 1024px) 780px, 92vw"
                    format="avif"
                    loading="lazy"
                  />
                  <!-- BEFORE (old template) wipes away to reveal it -->
                  <div class="wipe__before" data-wipe>
                    <Image
                      class="frame__img"
                      src={anaBefore}
                      alt="The original Ana's Confections template site, before the rebuild."
                      width={1280}
                      sizes="(min-width: 1024px) 780px, 92vw"
                      format="avif"
                      loading="lazy"
                    />
                    <span class="wipe__tag">Before</span>
                  </div>
                  <span class="wipe__handle" data-wipe-handle aria-hidden="true"></span>
                  <span class="wipe__tag wipe__tag--after">After</span>
                </div>

                <!-- == CLOSING wordmark (also the no-JS settled end-state) == -->
                <div class="closing" data-closing>
                  <span class="closing__mark">Slate &amp; Co.</span>
                  <p class="closing__line">One maker. Real rebuilds.</p>
                </div>

                <span class="screen__vignette" aria-hidden="true"></span>
              </div>
            </div>
            <div class="laptop__base" aria-hidden="true">
              <span class="laptop__hinge"></span>
            </div>
          </figure>

          <!-- PHONE — hidden until the morph beat, then scales up centered
               over the receding laptop, screen showing the real mobile layout. -->
          <figure class="phone" data-phone aria-hidden="true">
            <span class="phone__notch" aria-hidden="true"></span>
            <div class="phone__screen">
              <Image
                class="phone__img"
                src={anaMobile}
                alt="The same Ana's Confections site shown on a phone."
                width={760}
                sizes="(min-width: 1024px) 280px, 56vw"
                format="avif"
                loading="lazy"
              />
            </div>
          </figure>
        </div>

        <!-- Reserve the caption's vertical room in flow (zero CLS) ... -->
        <div class="showcase__capspace" aria-hidden="true"></div>
        <!-- ... while the caption itself is absolutely positioned inside it.
             Lives just below the device; never over it. Static = hidden (the
             list below carries the no-JS content). -->
        <div class="showcase__caption" data-caption aria-hidden="true">
          {
            features.map((feat) => (
              <p class="cap" data-cap={feat.n}>
                <span class="cap__kicker">{feat.kicker}</span>
                <span class="cap__line">{feat.line}</span>
              </p>
            ))
          }
        </div>
      </div>

      <p class="showcase__credit">
        A real rebuild: <strong>Ana&rsquo;s Confections</strong>, Rosenberg TX.
      </p>

    </div>
    </div>
  </div>

  <!-- == STATIC / NO-JS / a11y list. OUTSIDE the sticky track so it never
       pins and never shifts. Always in the DOM so all six features are legible
       without the demo; the live island hides it (the screen plays them). == -->
  <ul class="showcase__list container container--feature" data-showcase-list>
    {
      features.map((feat) => (
        <li class="svc">
          <span class="svc__num">{feat.n}</span>
          <div>
            <p class="svc__title">{feat.kicker}</p>
            <p class="svc__body">{feat.line}</p>
          </div>
        </li>
      ))
    }
  </ul>
</section>

<script>
  // ----------------------------------------------------------------------
  // Island-on-visible: load GSAP + wire the scrubbed demo only when the
  // section nears the viewport, and only when motion is allowed. Everything
  // is progressive enhancement over the complete static markup above.
  // ----------------------------------------------------------------------
  type STModule = typeof import("gsap/ScrollTrigger");

  const section = document.querySelector<HTMLElement>("#showcase");
  if (section) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");

    let built = false;
    let teardown: (() => void) | null = null;

    // Wait for fonts + a couple of frames so ScrollTrigger pins against the
    // FINAL geometry — late text/image paint can't then shift the pinned
    // layout (keeps CLS at 0 in cold Lighthouse runs).
    function settled(): Promise<void> {
      return new Promise((resolve) => {
        const ready = (document as any).fonts?.ready ?? Promise.resolve();
        ready.then(() => {
          requestAnimationFrame(() =>
            requestAnimationFrame(() => resolve())
          );
        });
      });
    }

    async function build() {
      if (built) return;
      built = true;

      const [{ gsap }, mod] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger") as Promise<STModule>,
        settled(),
      ]);
      const ScrollTrigger = mod.ScrollTrigger;
      gsap.registerPlugin(ScrollTrigger);

      const q = <T extends HTMLElement = HTMLElement>(sel: string) =>
        section!.querySelector<T>(sel);
      const qa = (sel: string) =>
        Array.from(section!.querySelectorAll<HTMLElement>(sel));

      const track = q("[data-showcase-track]");
      const pin = q("[data-showcase-pin]");
      const device = q("[data-showcase-device]");
      const laptop = q("[data-laptop]");
      const phone = q("[data-phone]");
      const hint = q("[data-showcase-hint]");
      const closing = q("[data-closing]");
      if (!track || !pin || !device || !laptop || !phone) return;

      const frame = (name: string) =>
        q(`[data-frame="${name}"]`);
      const f = {
        hero: frame("hero"),
        gallery: frame("gallery"),
        google: frame("google"),
        wipe: frame("wipe"),
      };
      const pan = q("[data-pan]");
      const cascade = qa("[data-cascade]");
      const speedcue = q("[data-speedcue]");
      const wipeBefore = q("[data-wipe]");
      const wipeHandle = q("[data-wipe-handle]");
      const caps = qa("[data-cap]");
      const cap = (n: string) => caps.find((c) => c.dataset.cap === n) || null;

      // Hand control to GSAP: CSS static end-state styles step aside.
      section!.classList.add("is-live");

      const ctx = gsap.context(() => {
        // ----- explicit start-state (transform / opacity / clip only) -----
        // Pronounced 3D tilt at rest; settles as it zooms in.
        gsap.set(device, { scale: 0.82, rotateX: 12, rotateY: -16, y: 10 });
        gsap.set(laptop, { autoAlpha: 1, scale: 1, transformOrigin: "50% 60%" });
        gsap.set(phone, { autoAlpha: 0, scale: 0.46, y: 8 });

        // Frames: only hero visible to open.
        const allFrames = [f.hero, f.gallery, f.google, f.wipe].filter(
          Boolean
        ) as HTMLElement[];
        gsap.set(allFrames, { autoAlpha: 0 });
        gsap.set(f.hero!, { autoAlpha: 1 });
        if (pan) gsap.set(pan, { scale: 1.18, yPercent: 0, xPercent: 0 });

        gsap.set(cascade, { yPercent: 16, autoAlpha: 0 });
        if (speedcue) gsap.set(speedcue, { autoAlpha: 0, scale: 0.9 });
        if (wipeBefore) gsap.set(wipeBefore, { clipPath: "inset(0 0% 0 0)" });
        if (wipeHandle) gsap.set(wipeHandle, { left: "100%", autoAlpha: 0 });

        gsap.set(caps, { autoAlpha: 0, y: 12 });
        if (closing) gsap.set(closing, { autoAlpha: 0, scale: 1.05 });

        // The pin is done by CSS `position: sticky` on the inner viewport, and
        // the TRACK reserves its full height statically — so there is NO
        // ScrollTrigger pin and NO spacer insertion. Nothing below ever shifts
        // (CLS = 0). ScrollTrigger only SCRUBS the timeline across the track's
        // travel (track height - one viewport).
        const tl = gsap.timeline({
          defaults: { ease: "none" },
          scrollTrigger: {
            trigger: track,
            start: "top top",
            end: "bottom bottom",
            scrub: 0.7,
            invalidateOnRefresh: true,
          },
        });

        const E = "power2.inOut";

        // helper to bring a caption in / out at given times
        const capIn = (n: string, at: number) => {
          const c = cap(n);
          if (c) tl.to(c, { autoAlpha: 1, y: 0, ease: "power2.out", duration: 0.04 }, at);
        };
        const capOut = (n: string, at: number) => {
          const c = cap(n);
          if (c) tl.to(c, { autoAlpha: 0, y: -10, ease: "power2.in", duration: 0.03 }, at);
        };

        // ============================================================
        // BEAT 0 (0.00 -> 0.08): OPEN. Laptop zooms in, tilt settles.
        // Real hero on screen. Hint fades.
        // ============================================================
        tl.to(device, { scale: 1, rotateX: 6, rotateY: -8, y: 0, ease: E, duration: 0.08 }, 0);
        if (hint) tl.to(hint, { autoAlpha: 0, duration: 0.03 }, 0.02);

        // ============================================================
        // BEAT 1 (0.08 -> 0.18): CUSTOM-DESIGNED.
        // Tilt goes flat; the screen does a slow, premium pan/zoom across
        // the bespoke hero (showing the craft). Caption 01.
        // ============================================================
        tl.to(device, { rotateX: 0, rotateY: 0, ease: E, duration: 0.06 }, 0.08);
        capIn("01", 0.1);
        if (pan)
          tl.to(pan, { scale: 1.04, yPercent: -10, xPercent: 4, ease: E, duration: 0.14 }, 0.06);

        // ============================================================
        // BEAT 2 (0.20 -> 0.32): LOADS IN ~1s.
        // Crossfade to the gallery; its rows SNAP up + a "0.8s" cue pops —
        // conveying an instant, crisp paint. Caption 02.
        // ============================================================
        capOut("01", 0.2);
        tl.to(f.hero!, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.2);
        tl.to(f.gallery!, { autoAlpha: 1, ease: E, duration: 0.04 }, 0.21);
        capIn("02", 0.23);
        // crisp cascade: rows snap in fast, slightly staggered
        tl.to(
          cascade,
          {
            yPercent: 0,
            autoAlpha: 1,
            ease: "power3.out",
            duration: 0.05,
            stagger: 0.018,
          },
          0.22
        );
        if (speedcue)
          tl.to(speedcue, { autoAlpha: 1, scale: 1, ease: "back.out(2)", duration: 0.05 }, 0.26);
        // fade the helper sheens back out so the real shot reads clean
        tl.to(cascade, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.3);

        // ============================================================
        // BEAT 3 (0.34 -> 0.48): RIGHT ON EVERY PHONE — the morph.
        // The laptop RECEDES + folds back; a PHONE scales up centered with
        // the real mobile layout. The money beat. Caption 03.
        // ============================================================
        capOut("02", 0.34);
        if (speedcue) tl.to(speedcue, { autoAlpha: 0, duration: 0.03 }, 0.34);
        // laptop recedes + tips back as if folding away
        tl.to(
          laptop,
          { scale: 0.74, autoAlpha: 0, rotateX: 18, y: 24, ease: E, duration: 0.1 },
          0.35
        );
        // phone rises into place, centered
        tl.to(
          phone,
          { autoAlpha: 1, scale: 1, y: 0, ease: "power3.out", duration: 0.11 },
          0.37
        );
        capIn("03", 0.42);

        // hold the phone a touch, then morph BACK to laptop for beat 4
        tl.to(phone, { scale: 0.46, autoAlpha: 0, y: 8, ease: E, duration: 0.08 }, 0.5);
        tl.to(
          laptop,
          { scale: 1, autoAlpha: 1, rotateX: 0, y: 0, ease: "power3.out", duration: 0.09 },
          0.52
        );
        capOut("03", 0.5);

        // ============================================================
        // BEAT 4 (0.54 -> 0.66): GOOGLE LISTING, HANDLED.
        // Screen shifts to the designed Google-Business mock (slides up).
        // Caption 04.
        // ============================================================
        tl.to(f.gallery!, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.54);
        tl.fromTo(
          f.google!,
          { autoAlpha: 0, yPercent: 6 },
          { autoAlpha: 1, yPercent: 0, ease: E, duration: 0.06 },
          0.55
        );
        capIn("04", 0.58);

        // ============================================================
        // BEAT 5 (0.68 -> 0.84): REAL BEFORE & AFTERS.
        // The old template fills the screen, then WIPES left-to-right to
        // reveal the rebuild underneath (handle tracks the seam). Caption 05.
        // ============================================================
        capOut("04", 0.68);
        tl.to(f.google!, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.68);
        tl.to(f.wipe!, { autoAlpha: 1, ease: E, duration: 0.04 }, 0.69);
        capIn("05", 0.72);
        if (wipeHandle) tl.set(wipeHandle, { autoAlpha: 1 }, 0.7);
        // wipe the BEFORE layer away (clip from the right), handle follows seam
        if (wipeBefore)
          tl.fromTo(
            wipeBefore,
            { clipPath: "inset(0 0% 0 0)" },
            { clipPath: "inset(0 100% 0 0)", ease: E, duration: 0.13 },
            0.72
          );
        if (wipeHandle)
          tl.fromTo(
            wipeHandle,
            { left: "100%" },
            { left: "0%", ease: E, duration: 0.13 },
            0.72
          );
        if (wipeHandle) tl.to(wipeHandle, { autoAlpha: 0, duration: 0.03 }, 0.85);

        // ============================================================
        // BEAT 6 (0.86 -> 1.00): ONE PERSON. Quiet close — the screen
        // settles to the Slate & Co. wordmark with a confident push-in.
        // Caption 06.
        // ============================================================
        capOut("05", 0.86);
        tl.to(f.wipe!, { autoAlpha: 0, ease: E, duration: 0.04 }, 0.86);
        if (closing)
          tl.to(closing, { autoAlpha: 1, scale: 1, ease: "power2.out", duration: 0.06 }, 0.87);
        capIn("06", 0.9);
        tl.to(device, { scale: 1.02, ease: "power1.out", duration: 0.06 }, 0.9);
      }, section!);

      teardown = () => {
        ctx.revert(); // kills timeline + ScrollTrigger, restores inline styles
        section!.classList.remove("is-live");
        built = false;
        teardown = null;
      };
    }

    function maybeBuild() {
      if (reduce.matches) return; // settled end-state via CSS; no JS motion
      build();
    }

    // Load slightly before the section scrolls into view.
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              io.disconnect();
              maybeBuild();
            }
          }
        },
        { rootMargin: "500px 0px 500px 0px" }
      );
      io.observe(section);
    } else {
      maybeBuild();
    }

    // If reduced-motion flips on while built, tear down to settled state.
    reduce.addEventListener("change", () => {
      if (reduce.matches && teardown) teardown();
    });

    // ---- Route-leave cleanup (View Transitions + bfcache) ----
    const cleanup = () => {
      if (teardown) teardown();
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
    window.addEventListener("pagehide", cleanup, { once: true });
  }
</script>

<style>
  /* =====================================================================
     STATIC / FALLBACK (default, no-JS, settled). The laptop shows the
     CLOSING wordmark frame; the six features render in a legible grid
     below it. Nothing is hidden behind the animation.
     ===================================================================== */
  .showcase {
    position: relative;
    background: var(--paper-2);
    border-block: 1px solid var(--hairline);
    overflow: clip;
  }

  /* TRACK: by default (no-JS / reduced-motion) it is just a normal block and
     the content flows at natural height. When scripting + motion are available
     (`.js-motion`, set before first paint), it reserves a tall scroll track so
     the sticky pin has travel — reserved in the INITIAL layout, so the later
     GSAP build inserts no spacer and shifts nothing below (CLS = 0). */
  .showcase__track {
    position: relative;
  }
  :global(.js-motion) .showcase__track {
    /* travel = track height - one sticky viewport. ~5 screens of scrub. */
    height: 600vh;
  }

  .showcase__pin {
    padding-block: var(--section-y);
  }
  /* When motion is on, the inner viewport STICKS for the whole track — this is
     the pin, done in pure CSS (works even before/without GSAP). */
  :global(.js-motion) .showcase__pin {
    position: sticky;
    top: 0;
    min-height: 100vh;
    padding-block: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: clip;
  }

  .showcase__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .showcase__head {
    max-width: 40ch;
    text-align: center;
  }

  .showcase__headline {
    margin-top: var(--space-16);
    font-size: var(--fs-h2);
    letter-spacing: var(--tracking-h2);
  }

  .showcase__scrollhint {
    margin-top: var(--space-16);
    font-family: var(--font-body);
    font-size: var(--fs-eyebrow);
    font-weight: 600;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    opacity: 0; /* only meaningful once live */
  }

  /* ---- Stage: device centered, caption beside it ---- */
  .showcase__stage {
    position: relative; /* caption anchors here */
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
