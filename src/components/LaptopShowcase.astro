    box-shadow: var(--shadow-3),
      0 0 calc(40px * var(--morph)) -8px var(--accent-glow);
    clip-path: inset(
      0 var(--bz-inset-x) 0 var(--bz-inset-x) round var(--bz-radius)
    );
    will-change: clip-path;
  }
  /* hairline accent edge — drawn INSIDE the clip so it follows the phone column */
  .laptop__bezel::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    border: 1px solid color-mix(in srgb, var(--hairline-strong) 80%, transparent);
